// Title: Rare or First-Time Process Execution
// Description: Identifies processes executed rarely or for the first time on an endpoint
// Data Source: DeviceProcessEvents
// MITRE ATT&CK:
//   Tactic: TA0002 - Execution
//   Technique: T1204 - User Execution
// Severity: Medium

DeviceProcessEvents
| summarize ExecutionCount = count()
    by DeviceName, FileName
| where ExecutionCount == 1
| project DeviceName, FileName