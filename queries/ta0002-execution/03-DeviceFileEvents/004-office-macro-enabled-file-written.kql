// Title: Office Macro-Enabled File Written
// Description: Detects Office macro-enabled files written to disk (.docm, .xlsm)
// Data Source: DeviceFileEvents
// MITRE ATT&CK:
//   Tactic: TA0002 - Execution
//   Technique: T1566 / T1204 - User Execution
// Severity: Medium

DeviceFileEvents
| where ActionType == "Created"
| where FileName endswith ".docm" or FileName endswith ".xlsm"
| project TimeGenerated, DeviceName, FileName, FolderPath, InitiatingProcessFileName
