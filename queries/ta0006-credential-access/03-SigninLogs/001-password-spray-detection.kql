// Title: Password Spray Detection
// Description: Detects multiple failed sign-ins for different users from a single IP within a short timeframe.
// Data Source: SigninLogs
// MITRE ATT&CK:
//   Tactic: TA0006 - Credential Access
//   Technique: T1110.001 - Password Spraying
// Severity: High

SigninLogs
| summarize FailedLogons = count() by IPAddress, bin(TimeGenerated, 1h)
| where FailedLogons >= 5
| project TimeGenerated, IPAddress, FailedLogons
| order by FailedLogons desc